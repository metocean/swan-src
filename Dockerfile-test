FROM metocean/swan:model-py3-gf
LABEL maintainer "Henrique Rapizo <h.rapizo@metocean.co.nz>"

ARG ftnref
ARG default_mode
ARG imp

# Reset ftn variable to compile reference model
ENV FTNREF=$ftnref
ENV DEFAULT_MODE=$default_mode
ENV INSTALL_SCRIPTS="/tmp/install_scripts"
ENV SWAN_TEST="/home/metocean"
ENV SWAN_SRC="/source/swan-src/swan_src"
ENV SWAN_IMP=$imp

# Compile and install model reference src to be compared with
COPY swan_src $SWAN_SRC
COPY install_scripts/install_swan-ref.sh $INSTALL_SCRIPTS/
COPY swan_src/patch/netcdf_multiple_compute3.patch $SWAN_SRC/ftn_${FTNREF}

# uncomment below for src version test
RUN ./$INSTALL_SCRIPTS/install_swan-ref.sh &&\
    rm -f $INSTALL_SCRIPTS/install_swan-ref.sh

# copy entrypoint
COPY install_scripts/entrypoint.sh $INSTALL_SCRIPTS/

RUN pip install --upgrade --no-cache-dir ipython \
                                         nco        \
                                         numpy \
                                         pandas \
                                         xarray \
                                         pytest \
                                         netCDF4 \
                                         ipdb

# copy since mounting does not work with bob
COPY tests/run_tinyapp.py /usr/local/bin/
COPY tests/${SWAN_IMP}.tar.gz /home/metocean
COPY tests/test_src.py /usr/local/bin/
COPY tests/conftest.py /usr/local/bin/
COPY tests/test_omp.py /usr/local/bin/
