# ARG SWAN_IMAGE_TAG_SUFFIX
# FROM metocean/swan:comp-${SWAN_IMAGE_TAG_SUFFIX}
FROM metocean/nvidia:22.11-plus_swan
LABEL maintainer "Henrique Rapizo <h.rapizo@metocean.co.nz>"

ARG USER_ID=1001
ARG GROUP_ID=1001
ARG USER_NAME=metocean

RUN apt -y update &&\
    apt -y upgrade &&\
    apt install -y vim \
    sudo \
    gdb \
    less &&\
    apt -y clean

RUN adduser -u $USER_ID $USER_NAME --disabled-password &&\
    chmod 666 /etc/sudoers &&\
    echo "$USER_NAME ALL=(ALL) NOPASSWD: ALL" >> /etc/sudoers &&\
    chmod 440 /etc/sudoers

ARG ftn
ARG default_mode

# Set required environment variables
ENV FTN=$ftn
ENV DEFAULT_MODE=$default_mode
ENV INSTALL_SCRIPTS="/tmp/install_scripts"
ENV SWAN_TEST="/home/metocean"
ENV SWAN_SRC="/source/swan-src/swan_src"

# Compile and install model
COPY swan_src $SWAN_SRC
COPY install_scripts/install_swan.sh $INSTALL_SCRIPTS/
RUN ./$INSTALL_SCRIPTS/install_swan.sh &&\
    rm -f $INSTALL_SCRIPTS/install_swan.sh

# # copy entrypoint
COPY install_scripts/entrypoint.sh $INSTALL_SCRIPTS/

CMD ["/bin/bash"]
