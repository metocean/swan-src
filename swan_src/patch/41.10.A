+    print OUTFILE "FLAGS90_MSC = -w -qfree=f90\n";
+    print OUTFILE "FLAGS_DYN =\n";
+    print OUTFILE "FLAGS_SER =\n";
+    print OUTFILE "FLAGS_OMP =\n";
